-- ---- Session time / FPS (верх-лево, т.к. Rayfield не даёт встроить это в свой сайдбар) ----
local sessionLabel = Instance.new("TextLabel")
sessionLabel.AnchorPoint = Vector2.new(0, 0)
sessionLabel.Position = UDim2.new(0.5, -120, 0, 20)
sessionLabel.Size = UDim2.new(0, 240, 0, 26)
sessionLabel.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
sessionLabel.BackgroundTransparency = 0.5
sessionLabel.Text = "Session 00:00 — 0 FPS"
sessionLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
sessionLabel.Font = Enum.Font.GothamBold
sessionLabel.TextSize = 14
sessionLabel.Parent = hudGui
Instance.new("UICorner", sessionLabel).CornerRadius = UDim.new(0, 5)

do
    local sessionStart = os.clock()
    local lastFpsUpdate, frameCount, fps = 0, 0, 0
    track(RunService.Heartbeat:Connect(function()
        frameCount = frameCount + 1
        local now = os.clock()
        if now - lastFpsUpdate >= 1 then
            fps = frameCount
            frameCount = 0
            lastFpsUpdate = now
        end
        sessionLabel.Visible = hudVisible
        local elapsed = math.floor(now - sessionStart)
        sessionLabel.Text = string.format("Session %02d:%02d — %d FPS", math.floor(elapsed / 60), elapsed % 60, fps)
    end))
end

