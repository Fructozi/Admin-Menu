        }):Play()
        if statusName then
            setFeatureStatus(statusName, state)
        end
        if fireCallback ~= false then
            onToggle(state)
        end
    end

    local function toggle()
        setState(not state)
    end

    local function getState()
        return state
    end

    hitButton.MouseButton1Click:Connect(toggle)

    return toggle, setState
