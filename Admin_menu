local enemyTeamMap = {}

local function rebuildEnemyTeamMap()
    table.clear(enemyTeamMap)
    local index = 1
    local myTeam = player.Team
    local teams = game:GetService("Teams"):GetChildren()
    table.sort(teams, function(a, b) return a.Name < b.Name end)
    for _, team in ipairs(teams) do
        if team ~= myTeam then
            enemyTeamMap[team] = index
            index += 1
        end
    end
end

local function getESPColorFor(plr)
    if plr.Team == player.Team then return espTeamColor end
    if next(enemyTeamMap) == nil then rebuildEnemyTeamMap() end
    local id = enemyTeamMap[plr.Team] or 1
    local colors = { espEnemyColor, espEnemyColor2, espEnemyColor3, espEnemyColor4, espEnemyColor5 }
    return colors[id] or espEnemyColor
end

local function removeESPFor(plr)
    local data = espObjects[plr]
    if data then
        if data.highlight then data.highlight:Destroy() end
        if data.billboard then data.billboard:Destroy() end
        espObjects[plr] = nil
    end
end

local function addESPFor(plr)
    if plr == player then return end
    local character = plr.Character
    if not character then return end
    removeESPFor(plr)

    local highlightColor = getESPColorFor(plr)
    local highlight = Instance.new("Highlight")
