local function persistSaves()
    pcall(function()
        local plain = {}
        for _, entry in ipairs(savedList) do
            table.insert(plain, { name = entry.name, x = entry.x, y = entry.y, z = entry.z })
        end
        writefile(saveFileName, HttpService:JSONEncode(plain))
    end)
end

local function loadSaves()
    local ok, data = pcall(function()
        if isfile and isfile(saveFileName) then
            return HttpService:JSONDecode(readfile(saveFileName))
        end
        return nil
    end)
    if ok and data then return data end
    return {}
end

local function savedNames()
    local names = {}
    for _, entry in ipairs(savedList) do table.insert(names, entry.name) end
    if #names == 0 then names = { "Нет сохранений" } end
