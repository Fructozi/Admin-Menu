-- ==================== Общий помощник: Toggle + свой Keybind + звук ====================
-- Модульная "фича" = один тумблер на нужной вкладке + один бинд сразу под
-- ним же (Rayfield сам сохраняет оба через ConfigurationSaving), плюс звук
-- 139658322785649 при любом включении/выключении - и по клику, и по бинду,
-- потому что оба пути идут через один и тот же apply().
local function createFeature(tab, name, flagPrefix, defaultValue, onChange)
    local toggleObj
    local function apply(state)
        onChange(state)
        playToggleSound()
    end

    toggleObj = tab:CreateToggle({
        Name = name,
        CurrentValue = defaultValue,
        Flag = flagPrefix .. "_Toggle",
        Callback = apply,
    })

    return toggleObj
end

